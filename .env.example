# Telegram Bot token from @BotFather
BOT_TOKEN=

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Conversation history length (number of messages kept per user)
MAX_HISTORY=20

# MySQL — either use a single URL (Railway provides MYSQL_URL automatically)
# MYSQL_URL=mysql://user:pass@host:3306/db

# ...or set individual variables (Railway also exposes these)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=umma_bot
